MOSS_ENVIRONMENT=development
MOSS_POSTGRES_DSN=postgresql://moss:moss@localhost:5432/moss
MOSS_REDIS_DSN=redis://localhost:6379/0
MOSS_DUCKDB_PATH=data/moss.duckdb
MOSS_GOVERNANCE_PATH=data/governance
MOSS_OBJECT_STORE_MODE=local
MOSS_LOCAL_ARCHIVE_PATH=data/archive
MOSS_MINIO_ENDPOINT=localhost:9000
MOSS_MINIO_ACCESS_KEY=minioadmin
MOSS_MINIO_SECRET_KEY=minioadmin
MOSS_MINIO_BUCKET=moss-artifacts
MOSS_CHOICE_MACRO_SERIES_JSON=[]
MOSS_CHOICE_MACRO_CATALOG_FILE=config/choice_macro_catalog.json
MOSS_CHOICE_MACRO_COMMANDS_FILE=
MOSS_CHOICE_NEWS_TOPICS_FILE=config/choice_news_topics.json
CHOICE_EMQUANT_PARENT=
CHOICE_MACRO_CHOICE_START_OPTIONS=
CHOICE_MACRO_CHOICE_REQUEST_OPTIONS=
VITE_DATA_SOURCE=mock
# 本地约定：后端 dev-api.ps1 使用 7888；前端 vite 5888。开发时前端 .env 可留空 VITE_API_BASE_URL 以走 Vite 代理。
VITE_API_BASE_URL=http://127.0.0.1:7888
VITE_JOB_POLL_INTERVAL_MS=250
VITE_JOB_POLL_MAX_ATTEMPTS=40

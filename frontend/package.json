{
  "name": "moss-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "debt:audit": "node ../scripts/audit_frontend_debt.mjs",
    "style:audit": "node ../scripts/audit_frontend_style_diff.mjs",
    "style:inventory": "node ../scripts/audit_frontend_style_inventory.mjs",
    "lint": "eslint .",
    "lint:openapi": "spectral lint ../.codex-tmp/openapi.json -r ../.spectral.yaml",
    "test": "vitest run",
    "test:a11y-smoke": "playwright test -c playwright.config.mjs",
    "test:a11y-smoke:headed": "playwright test -c playwright.config.mjs --headed",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "ag-grid-community": "^35.2.1",
    "ag-grid-react": "^35.2.1",
    "antd": "^5.0.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "write-excel-file": "^4.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@stoplight/spectral-cli": "^6.15.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
